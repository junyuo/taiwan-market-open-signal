---
import type { DataStatus, MarketSnapshot } from '../lib/indicators';
import { formatDateTime } from '../lib/format';

interface Props {
  snapshot: MarketSnapshot;
  status: DataStatus;
}

const { snapshot, status } = Astro.props;

const repositoryUrl = 'https://github.com/junyuo/taiwan-market-open-signal';
const updateWorkflowUrl = `${repositoryUrl}/actions/workflows/update-data.yml`;
const outcomeWorkflowUrl = `${repositoryUrl}/actions/workflows/collect-outcome.yml`;
const actionsUrl = `${repositoryUrl}/actions`;
---

<section class="manual-card" aria-labelledby="manual-update-title">
  <div class="section-head">
    <div>
      <p>MANUAL OPERATIONS</p>
      <h2 id="manual-update-title">手動更新與驗證</h2>
    </div>
    <span>需 GitHub repo 權限</span>
  </div>

  <div class="manual-body">
    <div class="status-strip" aria-label="目前資料狀態">
      <div><span>訊號日期</span><strong>{snapshot.date}</strong></div>
      <div><span>更新時間</span><strong>{formatDateTime(snapshot.generatedAt)}（台北）</strong></div>
      <div><span>資料品質</span><strong class:list={['quality', snapshot.dataQuality.status]}>{snapshot.dataQuality.status}</strong></div>
      <div><span>最後完整成功</span><strong>{status.lastSuccessfulUpdate ? `${formatDateTime(status.lastSuccessfulUpdate)}（台北）` : '尚無紀錄'}</strong></div>
    </div>

    <div class="actions" aria-label="手動操作連結">
      <a class="primary-action" href={updateWorkflowUrl} target="_blank" rel="noreferrer">
        手動更新盤前資料
        <span>Run workflow → fetch、validate、test、build、commit、deploy</span>
      </a>
      <a href={outcomeWorkflowUrl} target="_blank" rel="noreferrer">
        手動回收台股結果
        <span>Run workflow → collect outcome、validate、test、build、commit、deploy</span>
      </a>
      <a href={actionsUrl} target="_blank" rel="noreferrer">
        查看執行紀錄
        <span>檢查 schedule、manual run、commit 與 Pages deploy 狀態</span>
      </a>
    </div>

    <p class="safety-note">
      此區只提供 GitHub Actions 入口，不在瀏覽器保存 token，也不直接呼叫 Yahoo、TWSE、FRED 或 GitHub API。
      進入 workflow 頁後，請用具備 repository 權限的 GitHub 帳號按下 <strong>Run workflow</strong>。
    </p>
  </div>
</section>

<style>
  .manual-card { margin-top: 1rem; overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--surface); box-shadow: var(--shadow); }
  .section-head { display: flex; align-items: end; justify-content: space-between; gap: 1rem; padding: var(--space-card); border-bottom: 1px solid var(--line); background: linear-gradient(90deg, color-mix(in srgb, var(--surface-2) 75%, transparent), transparent); }
  .section-head p { margin: 0 0 .35rem; color: var(--muted); font-size: var(--font-xs); font-weight: 800; letter-spacing: .14em; }
  h2 { margin: 0; font-size: 1.25rem; }
  .section-head > span { color: var(--muted); font-size: var(--font-sm); }
  .manual-body { padding: var(--space-card); }
  .status-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: .65rem; }
  .status-strip > div { min-width: 0; padding: .72rem .78rem; border: 1px solid color-mix(in srgb, var(--line) 82%, transparent); border-radius: var(--radius-md); background: color-mix(in srgb, var(--surface-2) 46%, transparent); }
  .status-strip span { display: block; margin-bottom: .28rem; color: var(--muted); font-size: var(--font-xs); }
  .status-strip strong { display: block; overflow-wrap: anywhere; color: var(--text-2); font-size: var(--font-sm); font-variant-numeric: tabular-nums; }
  .quality { text-transform: uppercase; }
  .quality.ok { color: var(--green); }
  .quality.degraded { color: var(--amber); }
  .quality.failed { color: var(--red); }
  .actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem; margin-top: .9rem; }
  a { display: grid; gap: .34rem; min-height: 5.2rem; padding: .9rem .95rem; border: 1px solid color-mix(in srgb, var(--line-strong) 72%, transparent); border-radius: var(--radius-md); color: var(--text); background: linear-gradient(145deg, color-mix(in srgb, var(--surface-3) 52%, transparent), color-mix(in srgb, var(--surface-2) 28%, transparent)); font-size: var(--font-body); font-weight: 850; text-decoration: none; box-shadow: var(--shadow-control); }
  a:hover, a:focus-visible { border-color: color-mix(in srgb, var(--blue) 58%, var(--line-strong)); background: color-mix(in srgb, var(--blue) 9%, var(--surface-2)); outline: 2px solid color-mix(in srgb, var(--blue) 45%, transparent); outline-offset: 2px; }
  a span { color: var(--muted); font-size: var(--font-xs); font-weight: 600; line-height: 1.45; }
  .primary-action { border-color: color-mix(in srgb, var(--blue) 42%, var(--line)); background: linear-gradient(145deg, color-mix(in srgb, var(--blue) 13%, var(--surface-2)), color-mix(in srgb, var(--surface-3) 42%, transparent)); }
  .safety-note { margin: .9rem 0 0; color: var(--muted); font-size: var(--font-sm); line-height: 1.65; }
  .safety-note strong { color: var(--text-2); }
  @media (max-width: 820px) {
    .status-strip { grid-template-columns: repeat(2, 1fr); }
    .actions { grid-template-columns: 1fr; }
    a { min-height: auto; }
  }
  @media (max-width: 520px) {
    .section-head { align-items: flex-start; flex-direction: column; gap: .45rem; }
    .status-strip { grid-template-columns: 1fr; }
  }
</style>
