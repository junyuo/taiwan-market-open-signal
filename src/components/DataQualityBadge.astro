---
import type { DataQuality } from '../lib/indicators';

interface Props {
  quality: DataQuality;
}

const { quality } = Astro.props;
const labels = { ok: '資料正常', degraded: '資料降級', failed: '資料失敗' };
---

<span class:list={['quality-badge', quality.status]} title={`成功 ${quality.successCount}／失敗 ${quality.failedCount}／過期 ${quality.staleCount}`}>
  <span class="dot" aria-hidden="true"></span>
  {labels[quality.status]}
</span>

<style>
  .quality-badge { display: inline-flex; align-items: center; gap: .45rem; min-height: 2.15rem; padding: .4rem .68rem; border: 1px solid; border-radius: 999px; font-size: var(--font-xs); font-weight: 750; white-space: nowrap; box-shadow: var(--shadow-control); }
  .dot { width: .45rem; height: .45rem; border-radius: 50%; background: currentColor; box-shadow: 0 0 0 3px color-mix(in srgb, currentColor 18%, transparent); }
  .ok { color: var(--green); border-color: color-mix(in srgb, var(--green) 38%, transparent); background: color-mix(in srgb, var(--green) 10%, var(--surface)); }
  .degraded { color: var(--amber); border-color: color-mix(in srgb, var(--amber) 35%, transparent); background: color-mix(in srgb, var(--amber) 9%, transparent); }
  .failed { color: var(--red); border-color: color-mix(in srgb, var(--red) 35%, transparent); background: color-mix(in srgb, var(--red) 9%, transparent); }
</style>
