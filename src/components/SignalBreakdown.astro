---
import type { MarketIndicator } from '../lib/indicators';
import { formatPercent } from '../lib/format';

interface Props { indicators: MarketIndicator[]; }
const { indicators } = Astro.props;
const scored = indicators.filter(({ isScored }) => isScored);
const contextCount = indicators.length - scored.length;
const strength = (score: number) => Math.min(100, Math.abs(score) / 3 * 100);
---

<section class="breakdown card" aria-labelledby="breakdown-title">
  <div class="section-head">
    <div><p>SCORE EXPLAINABILITY</p><h2 id="breakdown-title">訊號拆解</h2></div>
    <span>{scored.length} 項計分 · {contextCount} 項背景觀察</span>
  </div>
  <div class="driver-grid">
    {scored.map((item) => (
      <article class:list={['driver', item.status !== 'ok' && 'unavailable', item.score > 0 ? 'driver-positive' : item.score < 0 ? 'driver-negative' : 'driver-neutral']} style={`--strength:${strength(item.score)}%`}>
        <div class="driver-top">
          <div><strong>{item.name}</strong><span>{formatPercent(item.changePercent)}</span></div>
          <b class:list={[item.score > 0 ? 'positive' : item.score < 0 ? 'negative' : 'neutral']}>
            {item.score > 0 ? `+${item.score}` : item.score}
          </b>
        </div>
        <p>{item.scoreReason}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .card { overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--surface); box-shadow: var(--shadow); }
  .section-head { display: flex; align-items: end; justify-content: space-between; gap: 1rem; padding: var(--space-card); border-bottom: 1px solid var(--line); background: linear-gradient(90deg, color-mix(in srgb, var(--surface-2) 75%, transparent), transparent); }
  .section-head p { margin: 0 0 .35rem; color: var(--muted); font-size: var(--font-xs); font-weight: 800; letter-spacing: .14em; }
  h2 { margin: 0; font-size: 1.25rem; }
  .section-head > span { color: var(--muted); font-size: var(--font-sm); }
  .driver-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .driver { position: relative; min-width: 0; padding: .9rem 1.1rem .95rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); background: linear-gradient(90deg, color-mix(in srgb, var(--driver-color, var(--muted)) 3.5%, transparent), transparent 42%); }
  .driver::after { position: absolute; bottom: 0; left: 0; width: var(--strength); height: 2px; background: var(--driver-color, var(--muted)); opacity: .5; content: ''; }
  .driver-positive { --driver-color: var(--red); }
  .driver-negative { --driver-color: var(--green); }
  .driver-neutral { --driver-color: var(--muted); }
  .driver:nth-child(2n) { border-right: 0; }
  .driver:nth-last-child(-n + 2) { border-bottom: 0; }
  .driver-top { display: flex; align-items: center; justify-content: space-between; gap: .8rem; }
  .driver-top div { display: flex; align-items: baseline; gap: .55rem; min-width: 0; }
  .driver-top strong { color: var(--text); font-size: .9rem; }
  .driver-top span { color: var(--muted); font-size: var(--font-sm); font-variant-numeric: tabular-nums; }
  b { min-width: 2.15rem; padding: .22rem .4rem; border: 1px solid color-mix(in srgb, currentColor 12%, transparent); border-radius: var(--radius-sm); text-align: center; font-size: var(--font-body); font-variant-numeric: tabular-nums; }
  .positive { color: var(--red); background: color-mix(in srgb, var(--red) 10%, transparent); }
  .negative { color: var(--green); background: color-mix(in srgb, var(--green) 10%, transparent); }
  .neutral { color: var(--muted); background: var(--surface-3); }
  article p { margin: .45rem 0 0; color: var(--text-2); font-size: var(--font-body); line-height: 1.5; }
  .unavailable { filter: saturate(.55); }
  .unavailable p, .unavailable .driver-top span { color: var(--muted); }
  @media (max-width: 720px) {
    .section-head { align-items: flex-start; padding: 1rem; }
    .section-head p { letter-spacing: .1em; white-space: nowrap; }
    .section-head > span { max-width: 9rem; text-align: right; line-height: 1.4; }
    .driver-grid { grid-template-columns: 1fr; }
    .driver, .driver:nth-child(2n), .driver:nth-last-child(-n + 2) { padding: .8rem .95rem .82rem; border-right: 0; border-bottom: 1px solid var(--line); }
    .driver:last-child { border-bottom: 0; }
  }
</style>
