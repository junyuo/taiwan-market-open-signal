---
import type { MarketIndicator } from '../lib/indicators';
import { CATEGORY_LABELS } from '../lib/indicators';
import { formatDateTime, formatNumber, formatPercent, formatSigned } from '../lib/format';

interface Props { indicators: MarketIndicator[]; }
const { indicators } = Astro.props;
const statusLabels = { ok: '正常', stale: '過期', failed: '失敗' };
---

<section class="table-card" aria-labelledby="indicator-title">
  <div class="section-head">
    <div>
      <p>GLOBAL INDICATORS</p>
      <h2 id="indicator-title">全球市場指標</h2>
    </div>
    <span>共 {indicators.length} 項</span>
  </div>
  <div class="scroll-hint" aria-hidden="true">左右滑動查看更多 →</div>
  <div class="table-scroll" tabindex="0" aria-label="全球市場指標，可橫向捲動">
    <table>
      <thead>
        <tr>
          <th>分類</th><th>指標</th><th class="num">最新值</th><th class="num">漲跌</th><th class="num">漲跌幅</th><th class="num">分數</th><th>狀態</th><th>來源</th><th>時間</th>
        </tr>
      </thead>
      <tbody>
        {indicators.map((item) => (
          <tr class:list={[item.status !== 'ok' && 'muted-row']}>
            <td><span class="category">{CATEGORY_LABELS[item.category]}</span></td>
            <td class="name"><strong>{item.name}</strong><small>{item.symbol} · {item.isScored ? '計分指標' : '背景觀察'}</small></td>
            <td class="num">
              {formatNumber(item.price)}
              {item.lastGood && <small class="last-good">上次 {formatNumber(item.lastGood.price)}<br />{formatDateTime(item.lastGood.timestamp)}</small>}
            </td>
            <td class:list={['num', item.change !== null && (item.change > 0 ? 'up' : item.change < 0 ? 'down' : '')]}>{formatSigned(item.change)}</td>
            <td class:list={['num', item.changePercent !== null && (item.changePercent > 0 ? 'up' : item.changePercent < 0 ? 'down' : '')]}>{formatPercent(item.changePercent)}</td>
            <td class:list={['num', item.score > 0 ? 'up' : item.score < 0 ? 'down' : '']}><strong>{item.score > 0 ? `+${item.score}` : item.score}</strong></td>
            <td><span class:list={['status', item.status]}>{statusLabels[item.status]}</span></td>
            <td class="source">{item.source}</td>
            <td class="time">{formatDateTime(item.timestamp)}{item.ageHours !== null && <small>{Math.max(0, item.ageHours).toFixed(1)} 小時前</small>}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .table-card { margin-top: 1rem; overflow: hidden; border: 1px solid var(--line); border-radius: var(--radius-lg); background: var(--surface); box-shadow: var(--shadow); }
  .section-head { display: flex; align-items: end; justify-content: space-between; padding: var(--space-card); border-bottom: 1px solid var(--line); background: linear-gradient(90deg, color-mix(in srgb, var(--surface-2) 75%, transparent), transparent); }
  .section-head p { margin: 0 0 .35rem; color: var(--muted); font-size: var(--font-xs); font-weight: 800; letter-spacing: .14em; }
  .section-head h2 { margin: 0; font-size: 1.25rem; }
  .section-head > span { color: var(--muted); font-size: .78rem; }
  .table-scroll { max-height: min(70vh, 720px); overflow: auto; scrollbar-color: var(--line-strong) var(--surface-2); scrollbar-width: thin; }
  .table-scroll:focus-visible { outline-offset: -3px; }
  .scroll-hint { display: none; }
  table { width: 100%; min-width: 1120px; border-collapse: collapse; }
  th, td { padding: .75rem .88rem; border-bottom: 1px solid color-mix(in srgb, var(--line) 82%, transparent); text-align: left; white-space: nowrap; }
  th { position: sticky; z-index: 5; top: 0; color: var(--muted); background: color-mix(in srgb, var(--surface-2) 96%, var(--bg)); box-shadow: 0 1px 0 var(--line), 0 8px 18px color-mix(in srgb, var(--text) 8%, transparent); font-size: var(--font-xs); font-weight: 750; letter-spacing: .02em; }
  td { color: var(--text-2); font-size: var(--font-body); }
  tbody tr:last-child td { border-bottom: 0; }
  tbody tr:nth-child(even) { background: color-mix(in srgb, var(--surface-2) 30%, transparent); }
  tbody tr:hover { background: color-mix(in srgb, var(--surface-3) 68%, transparent); }
  .num { text-align: right; font-variant-numeric: tabular-nums; }
  .name strong { display: block; color: var(--text); }
  .name small { display: block; margin-top: .15rem; color: var(--muted); font-size: var(--font-xs); }
  .last-good { display: block; margin-top: .25rem; color: var(--amber); font-size: var(--font-xs); font-weight: 600; line-height: 1.35; }
  .category { display: inline-flex; padding: .18rem .38rem; border: 1px solid color-mix(in srgb, var(--line) 75%, transparent); border-radius: var(--radius-sm); color: var(--text-2); background: color-mix(in srgb, var(--surface-3) 52%, transparent); font-size: var(--font-xs); }
  .status { display: inline-flex; min-width: 2.8rem; justify-content: center; padding: .2rem .4rem; border: 1px solid color-mix(in srgb, currentColor 14%, transparent); border-radius: var(--radius-sm); font-size: var(--font-xs); font-weight: 800; }
  .status.ok { color: var(--green); background: color-mix(in srgb, var(--green) 10%, transparent); }
  .status.stale { color: var(--amber); background: color-mix(in srgb, var(--amber) 10%, transparent); }
  .status.failed { color: var(--red); background: color-mix(in srgb, var(--red) 10%, transparent); }
  .up { color: var(--red); }
  .down { color: var(--green); }
  .muted-row { background: color-mix(in srgb, var(--amber) 5%, var(--surface)); }
  .source, .time { color: var(--muted); }
  .time small { display: block; margin-top: .15rem; font-size: var(--font-xs); }
  @media (max-width: 720px) {
    .section-head { padding: 1rem; }
    .table-scroll { max-height: none; overflow-x: auto; overflow-y: visible; }
    .scroll-hint { display: block; padding: .48rem 1rem; border-bottom: 1px solid var(--line); color: var(--amber); background: color-mix(in srgb, var(--surface-2) 80%, transparent); font-size: var(--font-xs); text-align: right; }
    th, td { padding: .68rem; }
    th { position: static; box-shadow: none; }
    th:first-child, td:first-child { position: sticky; left: 0; z-index: 3; width: 82px; min-width: 82px; background: var(--surface); }
    th:nth-child(2), td:nth-child(2) { position: sticky; left: 82px; z-index: 3; width: 145px; min-width: 145px; background: var(--surface); box-shadow: 8px 0 12px rgba(0, 0, 0, .2); }
    tbody tr:nth-child(even) td:first-child, tbody tr:nth-child(even) td:nth-child(2) { background: color-mix(in srgb, var(--surface-2) 72%, var(--surface)); }
    thead th:first-child, thead th:nth-child(2) { z-index: 4; background: var(--surface-2); }
  }
</style>
