---
import type { MarketSignal } from '../lib/indicators';
import MarketNarrative from './MarketNarrative.astro';

interface Props { signal: MarketSignal; }
const { signal } = Astro.props;
const score = `${signal.score >= 0 ? '+' : ''}${signal.score}`;
---

<section class:list={['signal-card', signal.bias]} aria-labelledby="signal-title">
  <div class="signal-head">
    <div>
      <p class="eyebrow">TODAY'S SIGNAL</p>
      <h2 id="signal-title">今日訊號：{signal.label}</h2>
    </div>
    <div class="score-box">
      <span>總分</span>
      <strong>{score}</strong>
    </div>
  </div>
  <MarketNarrative summary={signal.summary} />
</section>

<style>
  .signal-card { position: relative; overflow: hidden; padding: clamp(1.3rem, 4vw, 2rem); border: 1px solid var(--line); border-radius: 1rem; background: linear-gradient(135deg, var(--surface-2), var(--surface)); box-shadow: var(--shadow); }
  .signal-card::before { position: absolute; inset: 0 auto 0 0; width: 4px; content: ''; background: var(--signal-color); }
  .strongly_bullish, .bullish { --signal-color: var(--red); }
  .neutral { --signal-color: var(--amber); }
  .strongly_bearish, .bearish { --signal-color: var(--green); }
  .signal-head { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; }
  .eyebrow { margin: 0 0 .65rem; color: var(--muted); font-size: .7rem; font-weight: 800; letter-spacing: .14em; }
  h2 { margin: 0; font-size: clamp(1.45rem, 5vw, 2.35rem); letter-spacing: -.035em; }
  .score-box { min-width: 6.4rem; padding: .8rem 1rem; border: 1px solid var(--line); border-radius: .75rem; background: var(--surface-3); text-align: right; }
  .score-box span { display: block; color: var(--muted); font-size: .72rem; }
  .score-box strong { display: block; margin-top: .1rem; color: var(--signal-color); font-size: 2rem; line-height: 1.1; font-variant-numeric: tabular-nums; }
  @media (max-width: 520px) { .signal-head { align-items: flex-start; } .score-box { min-width: 5rem; } }
</style>
