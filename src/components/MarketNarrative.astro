---
interface Props { summary: string; }
const { summary } = Astro.props;
---

<div class="narrative">
  <span aria-hidden="true">觀察</span>
  <p>{summary}</p>
</div>

<style>
  .narrative { display: grid; grid-template-columns: auto 1fr; align-items: start; gap: .75rem; margin-top: 1.15rem; padding-top: 1rem; border-top: 1px solid color-mix(in srgb, var(--line) 78%, transparent); }
  span { padding: .23rem .42rem; border: 1px solid color-mix(in srgb, var(--line) 70%, transparent); border-radius: var(--radius-sm); background: color-mix(in srgb, var(--surface-3) 78%, transparent); color: var(--muted); font-size: var(--font-xs); font-weight: 800; letter-spacing: .08em; }
  p { margin: 0; color: var(--text-2); font-size: clamp(var(--font-body), 2vw, 1rem); line-height: 1.65; }
  @media (max-width: 520px) { .narrative { gap: .6rem; } p { line-height: 1.58; } }
</style>
